# =============================================================================
# Edge-Auth0 E2E Test Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Edge Gateway Configuration
# -----------------------------------------------------------------------------
EDGE_URL=https://your-edge-gateway-url

# Edge Admin API (for configuration deployment)
EDGE_ADMIN_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Auth0 OIDC Configuration
# Per kombify-Core/standards/AUTH0-DOPPLER-STANDARD.md §2 (binding):
#   AUTH0_DOMAIN = custom-domain host
#   AUTH0_ISSUER = issuer URL (with trailing slash; primary)
#   AUTH0_ADDITIONAL_ISSUERS = legacy issuers accepted in parallel
# -----------------------------------------------------------------------------
AUTH0_DOMAIN=login.kombify.io
AUTH0_ISSUER=https://login.kombify.io/
AUTH0_ADDITIONAL_ISSUERS=https://kombify.eu.auth0.com/
AUTH0_AUDIENCE=https://api.kombify.io
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# KombiSphere Application
# -----------------------------------------------------------------------------
KOMBISPHERE_URL=https://app.kombify.io

# -----------------------------------------------------------------------------
# Test Email Configuration (testmail.app)
# -----------------------------------------------------------------------------
# Get your namespace from https://testmail.app
TESTMAIL_NAMESPACE=your-namespace
TESTMAIL_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# Test Credentials (for existing user tests)
# -----------------------------------------------------------------------------
# Create a test user in Auth0 for automated testing
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test-password

# -----------------------------------------------------------------------------
# Redis Configuration (for rate limiting tests)
# -----------------------------------------------------------------------------
REDIS_HOST=your-redis-host
REDIS_PORT=6380
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true

# -----------------------------------------------------------------------------
# Azure Configuration
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_KEYVAULT_NAME=your-keyvault-name

# -----------------------------------------------------------------------------
# CI/CD Configuration
# -----------------------------------------------------------------------------
CI=false
HEADLESS=true
